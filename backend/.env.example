# Required in production. In local dev, backend falls back to a safe default.
JWT_SECRET=replace-with-a-strong-secret

# Optional token TTL. Examples: 12h, 1d, 7d
JWT_EXPIRES_IN=1d

# App
PORT=3000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/container_inspect

# Optional Cloudinary config
# CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
